# Copy this file to .env and fill in your values.

# API keys — set whichever matches your chosen provider.
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...

# Model to use for security evaluation.
# Format: <provider>/<model-name>  (litellm routing)
# LLM_MODEL=openai/gpt-4o-mini
# LLM_MODEL=anthropic/claude-3-5-sonnet-20241022
# LLM_MODEL=gemini/gemini-1.5-pro

# ── Langfuse observability (optional) ────────────────────────────────────────
# If unset, tracing is silently skipped — no code changes required.
# Get your keys at https://cloud.langfuse.com (or point HOST at self-hosted).
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
